# Slack bot token — starts with xoxb-
SLACK_BOT_TOKEN=xoxb-your-token-here

# Your Slack user ID (already set for you)
SLACK_USER_ID=U06G91AS63X

# Google OAuth — no env vars needed.
# Place credentials.json (downloaded from Google Cloud Console) in this directory,
# then run: python auth.py
# That creates token.json which the app uses automatically.
